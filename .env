# ══════════════════════════════════════════════════════════════
# ELWARDANI — Anomaly Detection System v3.0
# Environment Configuration
# ══════════════════════════════════════════════════════════════

# Flask
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
SECRET_KEY=elwardani-secret-2026-CHANGE-THIS-TO-SOMETHING-RANDOM

# CORS — allowed frontend origins (add your domain)
ALLOWED_ORIGINS=https://elwardani.me,https://www.elwardani.me,http://localhost:5000,http://127.0.0.1:5000

# Rate limiting
RATE_LIMIT=60/minute

# Payload & URL limits
MAX_PAYLOAD_SIZE=1048576
MAX_URL_LENGTH=2048
MAX_CONTENT_LENGTH=6000

# Isolation Forest ML model settings
ISOLATION_FOREST_N_ESTIMATORS=200
ISOLATION_FOREST_CONTAMINATION=0.05
ISOLATION_FOREST_RANDOM_STATE=42

# Logging
LOG_LEVEL=INFO

# Security (set to true when running behind HTTPS reverse proxy)
ENFORCE_HTTPS=true

# Dataset path (relative to app.py)
DATASET_PATH=dataset.csv