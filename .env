# Flask Configuration
FLASK_ENV=development
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_64_PLUS_CHARS

# CORS — include 'null' so file:// works locally
ALLOWED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000,null

# Dataset Configuration
DATASET_PATH=dataset.csv

# Isolation Forest Configuration
ISOLATION_FOREST_N_ESTIMATORS=200
ISOLATION_FOREST_CONTAMINATION=0.05
ISOLATION_FOREST_RANDOM_STATE=42

# Request Limits
MAX_PAYLOAD_SIZE=1048576
MAX_URL_LENGTH=2048
MAX_CONTENT_LENGTH=6000
MAX_FEATURES_LENGTH=100
RATE_LIMIT=60/minute




ALLOWED_ORIGINS=https://yourdomain.me,https://www.yourdomain.me
FLASK_ENV=production
ENFORCE_HTTPS=true


# Datadog Configuration
DD_API_KEY=your_datadog_api_key_here
DD_APP_KEY=your_datadog_app_key_here
DD_SITE=datadoghq.com          # or datadoghq.eu for EU accounts
DD_SERVICE=elwardani
DD_ENV=development
DD_VERSION=3.0
DD_AGENT_HOST=127.0.0.1
DD_AGENT_PORT=8125

# Security
ENFORCE_HTTPS=false

# Logging
LOG_LEVEL=INFO